## ============================================================
## HSM — Healthcare Management System
## Environment Variables Template
## Copy this file to .env and fill in your real values
## ============================================================

# ===== MySQL =====
MYSQL_ROOT_PASSWORD=your_mysql_root_password
MYSQL_DATABASE=hms
MYSQL_USER=hms
MYSQL_PASSWORD=your_mysql_password
MYSQL_ACCOUNT=root

# ===== Redis =====
REDIS_URL=redis://redis:6379
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379

# ===== JWT (shared across all secured services) =====
JWT_TOKEN_SECRET=your_jwt_secret_key_here_min_64_chars

# ===== OpenAI — cdss-service =====
OPENAI_API_KEY=sk-your_openai_api_key
OPENAI_MODEL=gpt-3.5-turbo
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# ===== Twilio — notification-service =====
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ===== SendGrid — notification-service =====
SENDGRID_API_KEY=SG.your_sendgrid_api_key

# ===== Cloudinary — community-portal-service =====
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ===== Frontend URL =====
FRONTEND_URL=http://localhost:5173

# ===== Health chatbot =====
HEALTH_CHATBOT_URI=http://health-chatbot:8000

# ===== Frontend / Vite - hsm-client =====
HSM_CLIENT_PORT=5173
VITE_APP_ENV=development
VITE_API_BASE_URL_DEV=http://localhost
VITE_API_BASE_URL_PROD=http://152.42.172.83
VITE_ZEGO_APP_ID=your_zego_app_id
VITE_ZEGO_SERVER_SECRET=your_zego_server_secret

# ===== Test Data Seeder =====
SEEDER_API_BASE_URL=http://api-gateway:8090
SEEDER_ADMIN_EMAIL=admin.seed@hsm.test
SEEDER_DEFAULT_PASSWORD=Test@12345
SEEDER_REQUEST_TIMEOUT_SECONDS=10
SEEDER_MAX_WAIT_SECONDS=180
SEEDER_RETRY_SECONDS=5

# ===== Zipkin =====
ZIPKIN_MYSQL_USER=root
ZIPKIN_MYSQL_PASS=your_zipkin_mysql_password

# ===== Spring Cloud / Eureka / Tracing (internal, not secrets) =====
SPRING_CONFIG_IMPORT=optional:configserver:http://config-server:8888
EUREKA_CLIENT_SERVICEURL_DEFAULTZONE=http://eureka-service-discovery:8761/eureka/
MYSQL_URL_JDBC=jdbc:mysql://mysql:3306/
MANAGEMENT_ZIPKIN_TRACING_ENDPOINT=http://zipkin:9411/api/v2/spans
MANAGEMENT_TRACING_SAMPLING_PROBABILITY=1.0
